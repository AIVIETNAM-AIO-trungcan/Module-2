"""
Project Git Ignore Configuration
--------------------------------
Purpose:
    This file specifies untracked files and directories that Git should ignore.
    It combines GitHub's official Python template with project-specific rule overrides.
"""

# ==============================================================================
# Python Bytecode and Cache (GitHub Default)
# ==============================================================================
__pycache__/
*.py[codz]
*$py.class
.pytest_cache/
.ipynb_checkpoints/
.ruff_cache/

# ==============================================================================
# Virtual Environments (Local sandbox isolation)
# ==============================================================================
.venv/
venv/
ENV/
env/
*.bak/

# ==============================================================================
# IDEs and Text Editors Settings (Local workspace preferences)
# ==============================================================================
.vscode/
.idea/
*.swp
.DS_Store
tempCodeRunnerFile.py

# ==============================================================================
# Streamlit & Secrets (Crucial for Deployment Security)
# ==============================================================================
.streamlit/secrets.toml

# ==============================================================================
# Project Specific Data & Artifacts Overrides (Security & Size Protection)
# ==============================================================================
# Block all raw and processed CSV datasets anywhere inside the data/ directory
data/**/*.csv

# Block all serialized models and preprocessors (.pkl or .joblib)
artifacts/**/*.pkl
artifacts/**/*.joblib

# Block all generated evaluation metrics and reports
artifacts/metrics/*

# Block all generated WOE tables and mathematical CSV reports inside artifacts folder
artifacts/**/*.csv

# Block all generated visual analysis plot images (.png, .jpg, etc.)
artifacts/plots/
artifacts/runs/**/plots/
*.png
*.jpg
*.jpeg